{
  "name": "opentp-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "React web UI for OpenTrackPlan — viewer + editor for analytics tracking plans",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "BUILD_LIB=1 vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vitest": "^3.0.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.0",
    "jsdom": "^25.0.0"
  }
}
